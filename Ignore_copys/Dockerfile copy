# 1. Define la imagen base de tu entorno de ejecución
FROM node:20-alpine

# 2. Establece el directorio de trabajo dentro del contenedor
WORKDIR /app

# 3. Copia los archivos de gestión de dependencias
COPY package*.json ./

# 4. Ejecuta comandos para instalar las dependencias
RUN npm install

# 5. Copia el resto del código fuente del proyecto
COPY . .

# 6. Indica el puerto que expondrá el contenedor
EXPOSE 3000

# 7. Define el comando por defecto que arrancará tu aplicación
CMD ["npm","run","start"]